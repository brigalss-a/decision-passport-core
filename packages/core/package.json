{
  "name": "@decision-passport/core",
  "version": "0.6.0",
  "description": "offline-verifiable authorization and execution receipts for AI and high-consequence software actions",
  "type": "module",
  "publishConfig": { "access": "public" },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/brigalss-a/decision-passport-core.git"
  },
  "homepage": "https://github.com/brigalss-a/decision-passport-core#readme",
  "bugs": {
    "url": "https://github.com/brigalss-a/decision-passport-core/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm run typecheck",
    "test": "vitest run"
  }
}
