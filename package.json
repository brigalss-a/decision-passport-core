{
  "name": "decision-passport-core-workspace",
  "private": true,
  "version": "0.6.0",
  "description": "offline-verifiable authorization and execution receipts for AI and high-consequence software actions",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "demo": "pnpm --filter @decision-passport/demo demo",
    "example:webhook-receipt": "tsx examples/reference-integrations/webhook-approval-receipt.ts",
    "example:agent-receipt": "tsx examples/reference-integrations/agent-tool-execution-receipt.ts",
    "example:smoke": "tsx scripts/check-reference-integrations.ts",
    "test": "pnpm -r test",
    "conformance": "tsx scripts/check-conformance-parity.ts",
    "verify-demo": "tsx scripts/verify-demo.ts",
    "diff-bundles": "tsx scripts/diff-bundles.ts",
    "diff-artifacts": "tsx scripts/generate-diff-artifacts.ts",
    "checksums": "tsx scripts/generate-checksums.ts"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
